meta {
  name: Update products
  type: http
  seq: 4
}

patch {
  url: {{baseUrl}}/products/:id-or-slug
  body: json
  auth: inherit
}

params:path {
  id-or-slug: 
}

headers {
  Accept: application/json
  Content-Type: application/json
}

body:json {
  {
    "name": "T-shirt v2",
    "status": "published",
    "inventory": {
      "price": 34.99
    },
    "category_ids": [1, 2]
  }
}
