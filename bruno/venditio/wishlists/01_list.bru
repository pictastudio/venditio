meta {
  name: List wishlists
  type: http
  seq: 91
}

get {
  url: {{baseUrl}}/wishlists
  body: none
  auth: inherit
}

params:query {
  ~all: 0
  ~page: 1
  ~per_page: 30
  ~sort_by: id
  ~sort_dir: asc
  ~id[]: 1
  ~user_id: 1
  ~name: Birthday
  ~slug: birthday
  ~description: gift
  ~is_default: 1
  ~with_trashed: 0
  ~only_trashed: 0
  ~include: user,items,items.product,products,products_count
}

headers {
  Accept: application/json
  Content-Type: application/json
}

docs {
  summary:
  - List wishlists

  endpoint:
  - method: GET
  - path: /wishlists

  query params:
  - all (boolean): Return all records without pagination.
  - page (integer): Page number used when all is false.
  - per_page (integer): Items per page.
  - sort_by (string): Sort field.
  - sort_dir (string): Sort direction: asc or desc.
  - id[] (integer[]): Filter by one or more wishlist IDs.
  - user_id (integer): Filter by owner user ID.
  - include (string|array): Optional includes: user, items, items.product, products, products_count.

  path params:
  - none

  body:
  - none
}
