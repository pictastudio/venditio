meta {
  name: Update product_collections
  type: http
  seq: 15
}

patch {
  url: {{baseUrl}}/product_collections/:id-or-slug
  body: json
  auth: inherit
}

params:query {
  ~include: products,products_count,tags,discounts,valid_discounts,expired_discounts
}

params:path {
  id-or-slug: 
}

headers {
  Accept: application/json
  Content-Type: application/json
  Locale: {{locale}}
}

body:json {
  {
    "name": "Updated Summer Picks",
    "description": "Updated editorial copy",
    "metadata": {
      "titolo": "Updated Summer Picks",
      "autore": null,
      "descrizione": "Updated editorial copy",
      "robots": null,
      "open_graph_titolo": "Updated Summer Picks",
      "open_graph_url": null,
      "open_graph_immagine": null,
      "open_graph_tipo": null,
      "twitter_card": null,
      "twitter_site": null,
      "twitter_creator": null,
      "twitter_titolo": "Updated Summer Picks",
      "twitter_descrizione": null,
      "twitter_src": null
    },
    "tag_ids": [1],
    "active": false
  }
}

docs {
  summary:
  - Update product_collections

  endpoint:
  - method: PATCH
  - path: /product_collections/:id-or-slug

  query params:
  - include (string|array): Optional includes: products, products_count, tags, discounts, valid_discounts, expired_discounts.

  path params:
  - id-or-slug: Replace with target resource identifier.

  body:
  - JSON payload.
  - Available fields:
  - name
  - slug
  - description
  - metadata (array)
  - tag_ids (array)
  - tag_ids.*
  - images (array|nullable)
  - images.*.id
  - images.*.file (file|image)
  - images.*.alt
  - images.*.name
  - images.*.mimetype
  - images.*.sort_order
  - images.*.type (nullable, thumb|cover)
  - active
  - visible_from
  - visible_until
  - {locale}.name / name:{locale}
  - {locale}.slug / slug:{locale}
  - {locale}.description / description:{locale}
  - Note: for image upload use multipart/form-data with fields like `images[0][file]` and `images[0][type]=thumb`.
  - Note: uploaded catalog images are stored under date subfolders (`YYYY/MM/DD`) inside their image type folder.
  - Note: existing images may be updated by id; only one `thumb` and one `cover` are allowed. A request can replace the current `thumb` or `cover` when it also releases the old typed image in the same `images` payload. `type=null` can be repeated for generic images.
}
