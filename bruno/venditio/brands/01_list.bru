docs {
  summary:
  - List brands

  endpoint:
  - method: GET
  - path: /brands

  query params:
  - all (boolean): Return all records without pagination.
  - page (integer): Page number used when all is false.
  - per_page (integer): Items per page (bounded by API config).
  - sort_by (string): Sort field. Allowed: id and filterable columns.
  - sort_dir (string): Sort direction: asc or desc.
  - id[] (integer[]): Filter by one or more resource IDs.
  - name (string): Exact-match filter for name.
  - slug (string): Exact-match filter for slug.
  - abstract (string): Exact-match filter for abstract.
  - description (string): Exact-match filter for description.
  - active (boolean): Exact-match filter for active.
  - show_in_menu (boolean): Exact-match filter for show_in_menu.
  - in_evidence (boolean): Exact-match filter for in_evidence.
  - sort_order (integer): Exact-match filter for sort_order.
  - created_at (date): Exact-match filter for created_at.
  - created_at_start (date): Filter created_at greater than or equal to this date.
  - created_at_end (date): Filter created_at less than or equal to this date.
  - updated_at (date): Exact-match filter for updated_at.
  - updated_at_start (date): Filter updated_at greater than or equal to this date.
  - updated_at_end (date): Filter updated_at less than or equal to this date.
  - deleted_at (date): Exact-match filter for deleted_at.
  - deleted_at_start (date): Filter deleted_at greater than or equal to this date.
  - deleted_at_end (date): Filter deleted_at less than or equal to this date.
  - with_trashed (boolean): Include soft deleted records in results.
  - only_trashed (boolean): Return only soft deleted records.
  - tag_ids[] (integer[]): Match brands assigned to at least one tag in this list.
  - include (string|array): Optional includes: tags.

  path params:
  - none

