docs {
  summary:
  - Update brands

  endpoint:
  - method: PATCH
  - path: /brands/:id-or-slug

  query params:
  - include (string|array): Optional includes: tags, products_count, discounts, valid_discounts, expired_discounts.

  path params:
  - id-or-slug: Replace with target resource identifier.

  body:
  - JSON payload.
  - Available fields:
  - name
  - slug
  - abstract
  - description
  - metadata (array)
  - images (array|nullable)
  - images.*.id
  - images.*.file (file|image)
  - images.*.alt
  - images.*.name
  - images.*.mimetype
  - images.*.sort_order
  - images.*.type (nullable, thumb|cover)
  - active
  - show_in_menu
  - in_evidence
  - sort_order
  - tag_ids (array)
  - tag_ids.*
  - {locale}.name (locale object notation)
  - {locale}.slug (locale object notation)
  - name:{locale} (locale suffix notation)
  - slug:{locale} (locale suffix notation)
  - {locale}.abstract / abstract:{locale}
  - {locale}.description / description:{locale}
  - Note: for image upload use multipart/form-data with fields like `images[0][file]` and `images[0][type]=thumb`.
  - Note: existing images may be updated by id; only one `thumb` and one `cover` are allowed. A request can replace the current `thumb` or `cover` when it also releases the old typed image in the same `images` payload. `type=null` can be repeated for generic images.
}
