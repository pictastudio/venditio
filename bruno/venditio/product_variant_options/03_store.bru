  Locale: {{locale}}
}

body:json {
  {
    "name": "Variant option 1 example",
    "product_variant_id": 1,
    "hex_color": "#FFAA00",
    "sort_order": 1
  }
}

docs {
  summary:
  - Store product_variant_options

  endpoint:
  - method: POST
  - path: /product_variant_options

  query params:
  - none

  path params:
  - none

  body:
  - JSON payload.
  - Available fields:
  - product_variant_id
  - name
  - image
  - hex_color
  - sort_order
  - {locale}.name (locale object notation)
  - name:{locale} (locale suffix notation)
  - Note: hex_color is accepted only when the linked product_variant has accept_hex_color=true.
}
